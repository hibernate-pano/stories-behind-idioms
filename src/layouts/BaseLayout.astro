---
import '~/styles/global.css';
import ThemeToggle from '~/components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
}
const {
  title,
  description = '成语背后的人和事',
  image = '/favicon.svg',
  ogType = 'article',
} = Astro.props;
const siteOrigin = Astro.site?.origin ?? '';
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImage = image.startsWith('http') ? image : `${siteOrigin}${image}`;
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL.href} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="成语背后的人和事" />
    <meta property="og:locale" content="zh_CN" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#FAF7F0" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1A1814" media="(prefers-color-scheme: dark)" />

    <title>{title}</title>
    <script is:inline>
      // Apply persisted theme before paint to avoid a flash of light mode.
      // is:inline keeps Astro from bundling this script so it runs synchronously.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') t = 'light';
          document.documentElement.setAttribute('data-theme', t);
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-to-content">跳转到正文</a>
    <nav class="top-nav">
      <a href="/" class="brand">成语背后的人和事</a>
      <div class="links">
        <a href="/browse">字母</a>
        <a href="/categories">分类</a>
        <ThemeToggle />
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <p>故事背后的人和事 · Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · © {new Date().getFullYear()}</p>
    </footer>
  </body>
</html>

<style is:global>
  .skip-to-content {
    position: absolute;
    top: -40px;
    left: 8px;
    z-index: 200;
    padding: 8px 12px;
    background: var(--color-accent);
    color: #FAF7F0;
    border-radius: 4px;
    border-bottom: none;
    font-family: var(--font-ui);
    font-size: 14px;
    transition: top 0.2s ease;
  }
  .skip-to-content:focus {
    top: 8px;
    outline: 2px solid var(--color-bg);
    outline-offset: 2px;
  }

  .top-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: calc(var(--space-unit) * 2) calc(var(--space-unit) * 3);
    border-bottom: 1px solid var(--color-line);
  }
  .brand {
    font-family: var(--font-body);
    font-weight: 600;
    border-bottom: none;
  }
  .links a {
    margin-left: var(--space-unit);
    border-bottom: none;
  }

  .site-footer {
    border-top: 1px solid var(--color-line);
    padding: calc(var(--space-unit) * 6) calc(var(--space-unit) * 3);
    margin-top: calc(var(--space-unit) * 12);
    text-align: center;
    color: var(--color-muted);
    font-family: var(--font-ui);
    font-size: 14px;
  }
  .site-footer p {
    margin: 0;
  }
  .site-footer a {
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-line);
  }
  .site-footer a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>
